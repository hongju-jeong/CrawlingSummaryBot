APP_DATABASE_URL=sqlite:///./app.db
APP_CRAWLER_TIMEOUT_SECONDS=10
APP_CRAWLER_MAX_ITEMS_PER_RUN=20
APP_CRAWLER_SCHEDULE_ENABLED=true
APP_CRAWLER_INTERVAL_MINUTES=10
APP_CRAWLER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36
APP_CRAWLER_SOURCE_NAME=Naver News Main
APP_CRAWLER_SOURCE_BASE_URL=https://news.naver.com/
APP_DEFAULT_REPORT_CHANNEL=Slack
APP_DEFAULT_REPORT_DESTINATION=#exec-briefing
APP_OPENAI_API_KEY=your_openai_api_key
APP_OPENAI_MODEL=gpt-5.4-mini
APP_OPENAI_REASONING_EFFORT=low
